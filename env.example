# Storage service environment

# MEDIA_ROOT is the filesystem root beneath which all persisted uploads live.
MEDIA_ROOT=./media

# STORAGE_PUBLIC_URL is the externally reachable base URL used to construct public media links.
STORAGE_PUBLIC_URL=http://localhost:4001

# STORAGE_ALLOWED_ORIGINS controls which browser origins may call the upload/delete endpoints (POST/OPTIONS).
STORAGE_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# MEDIA_CORS_ALLOWLIST controls which browser origins can fetch media from /api/media (supports "*" or explicit hosts).
MEDIA_CORS_ALLOWLIST=http://localhost:3000,http://localhost:3001

# Toggle to require signed media download URLs (default: disabled).
MEDIA_REQUIRE_SIGNED_DOWNLOAD=false

# UPLOAD_SIGNING_PUBLIC_KEY is the PEM file used to verify upload/delete grants.
UPLOAD_SIGNING_PUBLIC_KEY=./keys/upload_public.pem

# Optional private key path for signing grants (needed only for tests, not runtime storage).
# UPLOAD_SIGNING_PRIVATE_KEY=./keys/upload_private.pem

# DAEMON_API_PASSWORD is a shared secret that daemon processes use when interacting with the storage worker.
DAEMON_API_PASSWORD=changeme

# PORT is the HTTP port that the storage worker listens on.
PORT=4001
